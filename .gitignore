# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# uploads (receipt images etc.)
/public/uploads

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma
playwright-report/index.html
test-results/.last-run.json

# scraper debug dump
scripts/sample-share-page.html

# script-generated reports (do not commit)
scripts/analyze-apple-login-result.json
scripts/crawl-apple-login-result.json
scripts/explore-apple-login-report.json
scripts/mcp-login-flow-report.json

# Python (local automation)
automation/.venv
automation/__pycache__
automation/**/__pycache__
automation/*.egg-info
automation/output/*
automation/accounts.txt
automation/error_logs/*