# Apple login page (default https://account.apple.com)
# AUTOMATION_APPLE_LOGIN_URL=https://account.apple.com

# Default timeout in milliseconds for login / steps
# AUTOMATION_TIMEOUT_MS=90000

# Run browser headless (1 = headless, 0 = headed). Default 0 for login flows.
# AUTOMATION_HEADLESS=0

# Proxy (optional). Example: socks5://user:pass@host:port or http://host:port
# AUTOMATION_PROXY=
