# Database: use DATABASE_URL for Vercel (recommended: pooler URL from Neon/Vercel Postgres/Supabase pooler)
# or set POSTGRES_* for local/Docker. On Vercel set DATABASE_URL for Production and a separate one for Preview.
DATABASE_URL=

POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=account_mall
POSTGRES_HOST=localhost
# 本机连 Docker 的 db 时用 5433，避免与本机 PostgreSQL 冲突
POSTGRES_PORT=5433

# Better Auth (required: BETTER_AUTH_SECRET must be at least 32 characters)
BETTER_AUTH_SECRET=""
# Production/Vercel: set to your site URL (e.g. https://your-app.vercel.app)
BETTER_AUTH_URL="http://localhost:3000"

# Site / Brand
SITE_NAME="Account Mall"
SITE_DESCRIPTION="卡密自动发卡平台 - 即买即发，安全可靠"
SITE_TAGLINE="数字商品，即买即发"
SITE_SUBTITLE="安全可靠的卡密自动发卡平台，支持多种数字商品类型"
ADMIN_PANEL_LABEL="管理后台"

# Email (Resend; optional, for order completion / restock notifications)
RESEND_API_KEY=""
EMAIL_FROM="Account Mall <onboarding@resend.dev>"

# Seed (admin account created by db:seed)
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="admin123456"
ADMIN_NAME="Admin"

# Alipay (optional; leave empty to disable payment)
ALIPAY_APP_ID=""
ALIPAY_PRIVATE_KEY=""
ALIPAY_PUBLIC_KEY=""

# Yipay / 易支付 (optional; when set, used instead of Alipay for payment URL)
YIPAY_PID=""
YIPAY_KEY=""
YIPAY_SUBMIT_URL="https://z-pay.cn/submit.php"
YIPAY_SITE_NAME="Account Mall"

# Cron (required in production: protects /api/cron/close-expired-orders; Vercel Cron sends Authorization: Bearer CRON_SECRET). Set in Vercel env.
CRON_SECRET=""
PENDING_ORDER_TIMEOUT_MS=900000

# Rate limit (development 下不生效，不做风控)
ORDER_RATE_LIMIT_POINTS=10
ORDER_QUERY_RATE_LIMIT_POINTS=30
MAX_PENDING_ORDERS_PER_IP=6

# 订单成功页 token 签名（至少 16 位；不设则回退 BETTER_AUTH_SECRET，开发环境有默认值）
ORDER_SUCCESS_TOKEN_SECRET=

# Cloudflare Turnstile (optional; leave empty to skip human verification)
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
# Client-side key (same value as TURNSTILE_SITE_KEY when using Turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""

# 免费共享（FREE_SHARED 商品：单笔数量、爬取来源从环境变量读取，不在商品表单中配置；价格固定为 0）
FREE_SHARED_SOURCE_URL=""
FREE_SHARED_MAX_QUANTITY_PER_ORDER=1
FREE_SHARED_SCRAPE_CACHE_TTL_MS=60000
FREE_SHARED_SCRAPE_TIMEOUT_MS=15000
FREE_SHARED_COOLDOWN_HOURS=1

# 自动化（Apple 登录入口 URL；未设置时默认 https://account.apple.com。建议使用浏览器自动化，勿改为直接 HTTP 请求）
AUTOMATION_APPLE_LOGIN_URL="https://account.apple.com"
# 调试：设为 1 或 true 时，每个 Playwright 操作会放慢约 400ms，便于肉眼观察；开发环境默认有头，配合使用即可看到浏览器
# AUTOMATION_DEBUG=1
# 强制有头/无头（不设则开发有头、生产无头）
# AUTOMATION_HEADLESS=false
