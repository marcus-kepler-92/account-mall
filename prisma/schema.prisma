generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DISTRIBUTOR
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  name             String
  emailVerified    Boolean
  image            String?
  role             UserRole      @default(DISTRIBUTOR)
  distributorCode     String?   @unique @db.VarChar(64)
  discountCodeEnabled Boolean   @default(false) // 是否启用该分销员的优惠码，默认关闭
  discountPercent     Decimal?  @db.Decimal(5, 2) // 折扣比例，如 5 表示 5%；启用优惠码时填写
  disabledAt          DateTime? // 分销员停用时设置，归因与登录可据此判断
  inviterId            String?   // 邀请人（上级分销员），仅分销员有意义
  createdAt        DateTime
  updatedAt        DateTime
  sessions         Session[]
  accounts         Account[]
  inviter          User?         @relation("InviterToInvitee", fields: [inviterId], references: [id])
  invitees         User[]        @relation("InviterToInvitee")
  invitationRewardReceived InvitationReward? @relation("InvitationRewardInvitee") // 作为被邀请人触发的邀请奖励
  ordersAsDistributor Order[]
  commissions      Commission[]
  withdrawals      Withdrawal[]
  invitationRewardsGiven InvitationReward[] @relation("InvitationRewardInviter")

  @@index([inviterId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime
  updatedAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

// 鈹€鈹€鈹€ Business Models 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum CardStatus {
  UNSOLD
  RESERVED
  SOLD
  DISABLED
}

enum OrderStatus {
  PENDING
  COMPLETED
  CLOSED
}

enum RestockSubscriptionStatus {
  PENDING
  NOTIFIED
  CANCELLED
}

enum ProductType {
  NORMAL
  FREE_SHARED
}

model Product {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  summary          String?       @db.VarChar(300)
  description      String?
  image            String?       @db.Text
  price            Decimal       @db.Decimal(10, 2)
  maxQuantity      Int           @default(10)
  status           ProductStatus @default(ACTIVE)
  productType      ProductType   @default(NORMAL)
  sourceUrl        String?       @db.Text
  pinnedAt         DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  cards              Card[]
  orders             Order[]
  tags               Tag[]
  restockSubscriptions RestockSubscription[]
}

model Tag {
  id        String             @id @default(cuid())
  name      String             @unique
  slug      String             @unique
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  products  Product[]
  guides    DistributorGuide[]
}

model Card {
  id                  String               @id @default(cuid())
  productId           String
  content             String
  status              CardStatus           @default(UNSOLD)
  orderId             String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  product             Product              @relation(fields: [productId], references: [id])
  order               Order?               @relation(fields: [orderId], references: [id])

  @@index([productId, status])
  @@index([orderId])
}

model Order {
  id                      String      @id @default(cuid())
  orderNo                 String      @unique
  productId               String
  distributorId           String?
  email                   String
  passwordHash            String
  quantity                  Int
  amount                    Decimal     @db.Decimal(10, 2)
  discountPercentApplied    Decimal?     @db.Decimal(5, 2) // 下单时若使用分销员优惠码，记录当时应用的折扣比例
  productNameSnapshot       String?     @db.VarChar(500) // 下单时商品名称快照，便于历史订单展示
  status                    OrderStatus @default(PENDING)
  paidAt                  DateTime?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  clientIp                String?     // For rate limit: max PENDING orders per IP
  product                 Product     @relation(fields: [productId], references: [id])
  distributor             User?       @relation(fields: [distributorId], references: [id])
  cards                   Card[]
  commissions             Commission[]
  invitationReward        InvitationReward? // 触发邀请奖励的订单（被邀请人首单）

  @@index([email])
  @@index([status, createdAt])
  @@index([clientIp, status])
  @@index([distributorId])
}

model RestockSubscription {
  id         String                  @id @default(cuid())
  productId  String
  ip         String
  email      String
  status     RestockSubscriptionStatus @default(PENDING)
  notifiedAt DateTime?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  product    Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, ip])
  @@index([productId, status])
}

enum CommissionStatus {
  PENDING
  SETTLED
  WITHDRAWN
}

model Commission {
  id             String          @id @default(cuid())
  orderId        String
  distributorId  String
  amount         Decimal         @db.Decimal(10, 2)
  status         CommissionStatus @default(PENDING)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  order          Order           @relation(fields: [orderId], references: [id])
  distributor    User             @relation(fields: [distributorId], references: [id])

  @@index([distributorId])
  @@index([orderId])
}

model CommissionTier {
  id             String   @id @default(cuid())
  minAmount      Decimal  @db.Decimal(12, 2) // 当周累计销售额下限
  maxAmount      Decimal  @db.Decimal(12, 2) // 当周累计销售额上限
  ratePercent    Decimal  @db.Decimal(5, 2) // 该档阶梯佣金比例，如 5 表示 5%
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sortOrder])
}

enum WithdrawalStatus {
  PENDING
  PAID
  REJECTED
}

model Withdrawal {
  id                String           @id @default(cuid())
  distributorId     String
  amount            Decimal          @db.Decimal(10, 2)
  status            WithdrawalStatus @default(PENDING)
  receiptImageUrl   String?          // 收款码图片 URL，申请提现时上传
  note              String?          @db.Text
  processedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  distributor       User             @relation(fields: [distributorId], references: [id])

  @@index([distributorId])
  @@index([status])
}

// 邀请奖励：被邀请人（分销员）首单完成时，给邀请人发放一笔固定金额，每名被邀请人只触发一次
model InvitationReward {
  id         String   @id @default(cuid())
  inviterId  String   // 邀请人（获得奖励的分销员）
  inviteeId  String   @unique // 被邀请人（触发奖励的分销员），唯一保证每人只发一次
  orderId    String   @unique // 触发奖励的订单（被邀请人首单），一对一
  amount     Decimal  @db.Decimal(10, 2)
  status     CommissionStatus @default(SETTLED) // 与 Commission 一致，便于并入可提现余额
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  inviter    User     @relation("InvitationRewardInviter", fields: [inviterId], references: [id])
  order      Order    @relation(fields: [orderId], references: [id])
  invitee    User     @relation("InvitationRewardInvitee", fields: [inviteeId], references: [id])

  @@index([inviterId])
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
}

model Announcement {
  id          String              @id @default(cuid())
  title       String
  content     String?             @db.Text
  status      AnnouncementStatus  @default(DRAFT)
  sortOrder   Int                 @default(0)
  publishedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
  @@index([status, sortOrder])
}

model DistributorGuide {
  id          String             @id @default(cuid())
  title       String
  content     String?            @db.Text // Markdown 正文
  tagId       String?
  sortOrder   Int                @default(0)
  status      AnnouncementStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime          @updatedAt
  tag         Tag?               @relation(fields: [tagId], references: [id])

  @@index([status, sortOrder])
}





