generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DISTRIBUTOR
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  name             String
  emailVerified    Boolean
  image            String?
  role             UserRole      @default(DISTRIBUTOR)
  distributorCode  String?       @unique @db.VarChar(64)
  disabledAt       DateTime?     // 分销员停用时设置，归因与登录可据此判断
  createdAt        DateTime
  updatedAt        DateTime
  sessions         Session[]
  accounts         Account[]
  ordersAsDistributor Order[]
  commissions      Commission[]
  withdrawals      Withdrawal[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime
  updatedAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

// 鈹€鈹€鈹€ Business Models 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum CardStatus {
  UNSOLD
  RESERVED
  SOLD
  DISABLED
}

enum OrderStatus {
  PENDING
  COMPLETED
  CLOSED
}

enum RestockSubscriptionStatus {
  PENDING
  NOTIFIED
  CANCELLED
}

enum ProductType {
  NORMAL
  FREE_SHARED
}

model Product {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  summary          String?       @db.VarChar(300)
  description      String?
  image            String?       @db.Text
  price            Decimal       @db.Decimal(10, 2)
  maxQuantity      Int           @default(10)
  status           ProductStatus @default(ACTIVE)
  productType      ProductType   @default(NORMAL)
  sourceUrl        String?       @db.Text
  commissionAmount Decimal?      @db.Decimal(10, 2) // 每件分销佣金 元
  pinnedAt         DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  cards              Card[]
  orders             Order[]
  tags               Tag[]
  restockSubscriptions RestockSubscription[]
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Card {
  id                  String               @id @default(cuid())
  productId           String
  content             String
  status              CardStatus           @default(UNSOLD)
  orderId             String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  product             Product              @relation(fields: [productId], references: [id])
  order               Order?               @relation(fields: [orderId], references: [id])

  @@index([productId, status])
  @@index([orderId])
}

model Order {
  id                      String      @id @default(cuid())
  orderNo                 String      @unique
  productId               String
  distributorId           String?
  email                   String
  passwordHash            String
  quantity                Int
  amount                  Decimal     @db.Decimal(10, 2)
  status                  OrderStatus @default(PENDING)
  paidAt                  DateTime?
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  clientIp                String?     // For rate limit: max PENDING orders per IP
  commissionAmountSnapshot Decimal?   @db.Decimal(10, 2) // 下单时商品每件佣金，完成时用此计算避免事后改价
  product                 Product     @relation(fields: [productId], references: [id])
  distributor             User?       @relation(fields: [distributorId], references: [id])
  cards                   Card[]
  commissions             Commission[]

  @@index([email])
  @@index([status, createdAt])
  @@index([clientIp, status])
  @@index([distributorId])
}

model RestockSubscription {
  id         String                  @id @default(cuid())
  productId  String
  ip         String
  email      String
  status     RestockSubscriptionStatus @default(PENDING)
  notifiedAt DateTime?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  product    Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, ip])
  @@index([productId, status])
}

enum CommissionStatus {
  PENDING
  SETTLED
  WITHDRAWN
}

model Commission {
  id             String          @id @default(cuid())
  orderId        String
  distributorId  String
  amount         Decimal         @db.Decimal(10, 2)
  status         CommissionStatus @default(PENDING)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  order          Order           @relation(fields: [orderId], references: [id])
  distributor    User             @relation(fields: [distributorId], references: [id])

  @@index([distributorId])
  @@index([orderId])
}

model CommissionTier {
  id             String   @id @default(cuid())
  minAmount      Decimal  @db.Decimal(12, 2) // 当周累计销售额下限
  maxAmount      Decimal  @db.Decimal(12, 2) // 当周累计销售额上限
  ratePercent    Decimal  @db.Decimal(5, 2) // 该档阶梯佣金比例，如 5 表示 5%
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sortOrder])
}

enum WithdrawalStatus {
  PENDING
  PAID
  REJECTED
}

model Withdrawal {
  id                String           @id @default(cuid())
  distributorId     String
  amount            Decimal          @db.Decimal(10, 2)
  status            WithdrawalStatus @default(PENDING)
  receiptImageUrl   String?          // 收款码图片 URL，申请提现时上传
  note              String?          @db.Text
  processedAt       DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  distributor       User             @relation(fields: [distributorId], references: [id])

  @@index([distributorId])
  @@index([status])
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
}

model Announcement {
  id          String              @id @default(cuid())
  title       String
  content     String?             @db.Text
  status      AnnouncementStatus  @default(DRAFT)
  sortOrder   Int                 @default(0)
  publishedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
  @@index([status, sortOrder])
}





