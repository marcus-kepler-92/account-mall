enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum CardStatus {
  UNSOLD
  RESERVED
  SOLD
  DISABLED
}

enum OrderStatus {
  PENDING
  COMPLETED
  CLOSED
}

enum RestockSubscriptionStatus {
  PENDING
  NOTIFIED
  CANCELLED
}

enum ProductType {
  NORMAL
  FREE_SHARED
}

enum AutomationCategory {
  APPLE
}

enum AutomationPresetType {
  STATUS_TEST
  CHANGE_PASSWORD
  CHANGE_REGION
}

enum AutomationTaskStatus {
  PENDING
  RUNNING
  SUCCESS
  PARTIAL_SUCCESS
  FAILED
}

enum AutomationTaskItemStatus {
  PENDING
  RUNNING
  SUCCESS
  FAILED
}
model Product {
  id          String        @id @default(cuid())
  name        String
  slug        String        @unique
  summary     String?       @db.VarChar(300)
  description String?
  image       String?       @db.Text
  price       Decimal       @db.Decimal(10, 2)
  maxQuantity Int           @default(10)
  status      ProductStatus @default(ACTIVE)
  productType ProductType   @default(NORMAL)
  sourceUrl   String?       @db.Text
  secretCode  String?       @db.VarChar(64)
  pinnedAt    DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  cards              Card[]
  orders             Order[]
  tags               Tag[]
  restockSubscriptions RestockSubscription[]
  automationPresets    ProductAutomationPreset[]
  automationTasks      AutomationTask[]
}

model Tag {
  id        String    @id @default(cuid())
  name      String    @unique
  slug      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  products  Product[]
}

model Card {
  id                  String               @id @default(cuid())
  productId           String
  content             String
  status              CardStatus           @default(UNSOLD)
  orderId             String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  product             Product              @relation(fields: [productId], references: [id])
  order               Order?               @relation(fields: [orderId], references: [id])
  automationTaskItems AutomationTaskItem[]

  @@index([productId, status])
  @@index([orderId])
}

model Order {
  id           String      @id @default(cuid())
  orderNo      String      @unique
  productId    String
  email        String
  passwordHash String
  quantity     Int
  amount       Decimal     @db.Decimal(10, 2)
  status       OrderStatus @default(PENDING)
  paidAt       DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  clientIp     String?     // For rate limit: max PENDING orders per IP
  product      Product     @relation(fields: [productId], references: [id])
  cards        Card[]

  @@index([email])
  @@index([status, createdAt])
  @@index([clientIp, status])
}

model RestockSubscription {
  id         String                  @id @default(cuid())
  productId  String
  ip         String
  email      String
  status     RestockSubscriptionStatus @default(PENDING)
  notifiedAt DateTime?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  product    Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, ip])
  @@index([productId, status])
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
}

model Announcement {
  id          String              @id @default(cuid())
  title       String
  content     String?             @db.Text
  status      AnnouncementStatus  @default(DRAFT)
  sortOrder   Int                 @default(0)
  publishedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
  @@index([status, sortOrder])
}

model ProductAutomationPreset {
  id          String               @id @default(cuid())
  productId   String
  category    AutomationCategory   @default(APPLE)
  presetKey   String
  name        String
  presetType  AutomationPresetType
  adapterKey  String
  configJson  Json?
  isEnabled   Boolean              @default(true)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt
  product     Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  tasks       AutomationTask[]

  @@unique([productId, presetKey])
  @@index([productId, category, isEnabled])
}

model AutomationTask {
  id           String               @id @default(cuid())
  category     AutomationCategory   @default(APPLE)
  productId    String
  presetId     String
  status       AutomationTaskStatus @default(PENDING)
  createdBy    String
  inputConfig  Json?
  summary      Json?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  product      Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  preset       ProductAutomationPreset @relation(fields: [presetId], references: [id], onDelete: Cascade)
  items        AutomationTaskItem[]
  logs         AutomationTaskLog[]

  @@index([category, status, createdAt])
  @@index([productId, createdAt])
  @@index([presetId])
}

model AutomationTaskItem {
  id            String                   @id @default(cuid())
  taskId         String
  cardId         String
  status         AutomationTaskItemStatus @default(PENDING)
  resultJson     Json?
  errorCode      String?
  errorMessage   String?
  retryCount     Int                      @default(0)
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  task           AutomationTask           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  card           Card                     @relation(fields: [cardId], references: [id], onDelete: Cascade)
  logs           AutomationTaskLog[]

  @@index([taskId, status])
  @@index([cardId])
  @@unique([taskId, cardId])
}

model AutomationTaskLog {
  id        String   @id @default(cuid())
  taskId    String
  itemId    String?
  level     String
  step      String
  message   String
  data      Json?
  createdAt DateTime @default(now())

  task AutomationTask      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  item AutomationTaskItem? @relation(fields: [itemId], references: [id], onDelete: SetNull)

  @@index([taskId, createdAt])
  @@index([itemId])
}

