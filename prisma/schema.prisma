generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  DISTRIBUTOR
}

model User {
  id               String        @id @default(cuid())
  email            String        @unique
  name             String
  emailVerified    Boolean
  image            String?
  role             UserRole      @default(DISTRIBUTOR)
  distributorCode     String?   @unique @db.VarChar(64)
  discountCodeEnabled Boolean   @default(false) // 是否启用该分销员的优惠码，默认关闭
  discountPercent     Decimal?  @db.Decimal(5, 2) // 折扣比例，如 5 表示 5%；启用优惠码时填写
  disabledAt          DateTime? // 分销员停用时设置，归因与登录可据此判断
  inviterId            String?   // 邀请人（上级分销员），仅分销员有意义
  createdAt        DateTime
  updatedAt        DateTime
  sessions         Session[]
  accounts         Account[]
  inviter          User?         @relation("InviterToInvitee", fields: [inviterId], references: [id])
  invitees         User[]        @relation("InviterToInvitee")
  ordersAsDistributor Order[]
  commissions      Commission[]
  withdrawals      Withdrawal[]
  distributorInvitationsSent DistributorInvitation[] @relation("DistributorInvitationInviter")

  @@index([inviterId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime
  updatedAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime
  updatedAt             DateTime
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String    @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime?
  updatedAt  DateTime?
}

// 鈹€鈹€鈹€ Business Models 鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€鈹€

enum ProductStatus {
  ACTIVE
  INACTIVE
}

enum CardStatus {
  UNSOLD
  RESERVED
  SOLD
  DISABLED
}

enum OrderStatus {
  PENDING
  COMPLETED
  CLOSED
}

enum RestockSubscriptionStatus {
  PENDING
  NOTIFIED
  CANCELLED
}

enum ProductType {
  NORMAL
  AUTO_FETCH
}

model Product {
  id               String        @id @default(cuid())
  name             String
  slug             String        @unique
  summary          String?       @db.VarChar(300)
  description      String?
  image            String?       @db.Text
  price            Decimal       @db.Decimal(10, 2)
  maxQuantity      Int           @default(10)
  status           ProductStatus @default(ACTIVE)
  productType      ProductType   @default(NORMAL)
  sourceUrl        String?       @db.Text
  /// AUTO_FETCH 商品的有效期（小时），默认 24；null 表示使用系统默认值
  validityHours    Int?
  pinnedAt         DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  cards              Card[]
  orders             Order[]
  tags               Tag[]
  restockSubscriptions RestockSubscription[]
  exitDiscountUsages ExitDiscountUsage[]
}

model Tag {
  id        String             @id @default(cuid())
  name      String             @unique
  slug      String             @unique
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  products  Product[]
  guides    DistributorGuide[]
}

model Card {
  id                  String               @id @default(cuid())
  productId           String
  content             String
  status              CardStatus           @default(UNSOLD)
  orderId             String?
  /// AUTO_FETCH：上次刷新时间，用于限流（1 分钟/次）
  lastRefreshedAt     DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  product             Product              @relation(fields: [productId], references: [id])
  order               Order?               @relation(fields: [orderId], references: [id])

  @@index([productId, status])
  @@index([orderId])
}

model Order {
  id                      String      @id @default(cuid())
  orderNo                 String      @unique
  productId               String
  distributorId           String?
  email                   String
  passwordHash            String
  quantity                  Int
  amount                    Decimal     @db.Decimal(10, 2)
  discountPercentApplied    Decimal?     @db.Decimal(5, 2) // 下单时若使用分销员优惠码，记录当时应用的折扣比例
  productNameSnapshot       String?     @db.VarChar(500) // 下单时商品名称快照，便于历史订单展示
  status                    OrderStatus @default(PENDING)
  paidAt                  DateTime?
  /// AUTO_FETCH：订单有效期截止时间；免费=创建时+validityHours，收费=支付时+validityHours
  expiresAt               DateTime?
  promoCode               String?     // 下单时使用的推荐码（冗余存储，便于查询）
  createdAt               DateTime    @default(now())
  updatedAt               DateTime    @updatedAt
  clientIp                String?     // For rate limit: max PENDING orders per IP
  fingerprintHash         String?     // 浏览器指纹，用于免费商品多因素领取限制
  exitDiscountMeta        String?     @db.Text // Exit intent 折扣信号 JSON，订单 COMPLETED 后转存到 ExitDiscountUsage
  product                 Product     @relation(fields: [productId], references: [id])
  distributor             User?       @relation(fields: [distributorId], references: [id])
  cards                   Card[]
  commissions             Commission[]
  exitDiscountUsage       ExitDiscountUsage?

  @@index([email])
  @@index([status, createdAt])
  @@index([clientIp, status])
  @@index([fingerprintHash])
  @@index([distributorId])
}

model RestockSubscription {
  id         String                  @id @default(cuid())
  productId  String
  ip         String
  email      String
  status     RestockSubscriptionStatus @default(PENDING)
  notifiedAt DateTime?
  createdAt  DateTime                @default(now())
  updatedAt  DateTime                @updatedAt
  product    Product                 @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, ip])
  @@index([productId, status])
}

enum CommissionStatus {
  PENDING
  SETTLED
  WITHDRAWN
}

model Commission {
  id                  String          @id @default(cuid())
  orderId             String
  distributorId       String
  amount              Decimal         @db.Decimal(10, 2)
  status              CommissionStatus @default(PENDING)
  /// 1=一级佣金（直接推广所得），2=二级佣金（下线推广触发）
  level               Int             @default(1)
  /// level=2 时记录触发该佣金的下线分销员 ID，便于追溯
  sourceDistributorId String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  order               Order           @relation(fields: [orderId], references: [id])
  distributor         User            @relation(fields: [distributorId], references: [id])

  @@index([distributorId])
  @@index([distributorId, level])
  @@index([orderId])
  @@index([sourceDistributorId])
}

model CommissionTier {
  id             String   @id @default(cuid())
  minAmount      Decimal  @db.Decimal(12, 2) // 当周累计销售额下限
  maxAmount      Decimal  @db.Decimal(12, 2) // 当周累计销售额上限
  ratePercent    Decimal  @db.Decimal(5, 2) // 该档阶梯佣金比例，如 5 表示 5%
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([sortOrder])
}

enum WithdrawalStatus {
  PENDING
  PAID
  REJECTED
}

model Withdrawal {
  id                String           @id @default(cuid())
  distributorId     String
  amount            Decimal          @db.Decimal(10, 2)
  status            WithdrawalStatus @default(PENDING)
  receiptImageUrl   String?          // 收款码图片 URL，申请提现时上传
  note              String?          @db.Text
  processedAt       DateTime?
  feePercent        Decimal?         @db.Decimal(5, 2)  // 手续费比例（创建时固化），如 2.00 表示 2%
  feeAmount         Decimal?         @db.Decimal(10, 2) // 手续费金额（创建时固化）
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  distributor       User             @relation(fields: [distributorId], references: [id])

  @@index([distributorId])
  @@index([status])
}

// 邀请奖励：被邀请人（分销员）首单完成时，给邀请人发放一笔固定金额，每名被邀请人只触发一次

/// 邀请分销员加入的邀请记录，支持管理员和分销员均可发起邀请
model DistributorInvitation {
  id         String    @id @default(cuid())
  email      String
  token      String    @unique
  inviterId  String    // 邀请人 ID（可以是 ADMIN 或 DISTRIBUTOR）
  expiresAt  DateTime
  acceptedAt DateTime?
  createdAt  DateTime  @default(now())
  inviter    User      @relation("DistributorInvitationInviter", fields: [inviterId], references: [id])

  @@index([token])
  @@index([email])
}

enum AnnouncementStatus {
  DRAFT
  PUBLISHED
}

model Announcement {
  id          String              @id @default(cuid())
  title       String
  content     String?             @db.Text
  status      AnnouncementStatus  @default(DRAFT)
  sortOrder   Int                 @default(0)
  publishedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([status])
  @@index([status, sortOrder])
}

model DistributorGuide {
  id          String             @id @default(cuid())
  title       String
  content     String?            @db.Text // Markdown 正文
  tagId       String?
  sortOrder   Int                @default(0)
  status      AnnouncementStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime          @updatedAt
  tag         Tag?               @relation(fields: [tagId], references: [id])

  @@index([status, sortOrder])
}

// Exit Intent 折扣使用记录：用于防止同一用户（按指纹/cookie/IP 三信号）重复领取离开挽留折扣
model ExitDiscountUsage {
  id              String   @id @default(cuid())
  productId       String
  orderId         String   @unique
  visitorId       String   // 持久 cookie __ed_vid
  fingerprintHash String   // FingerprintJS visitorId hash
  ip              String
  usedAt          DateTime @default(now())

  product Product @relation(fields: [productId], references: [id])
  order   Order   @relation(fields: [orderId], references: [id])

  @@index([productId, visitorId])
  @@index([productId, fingerprintHash])
  @@index([productId, ip])
}





